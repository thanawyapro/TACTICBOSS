# Optional build-time public Supabase configuration.
# The Supabase Project URL and anon/public key are safe for the client when Row Level Security is correctly configured.
# Never place a service-role key, JWT secret, database password, or private key in frontend environment variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional real Vision AI provider for Netlify Function. Add ONE provider in Netlify → Site configuration → Environment variables.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Launch safety: keep this true/default in production.
REQUIRE_AUTH_FOR_AI=true
ALLOW_AI_WITHOUT_USAGE_GUARD=false
MAX_VISION_IMAGE_CHARS=1800000
