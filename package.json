{
  "name": "tactic-boss-ai",
  "private": true,
  "version": "1.31.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "check": "npm run lint && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "audit:release": "node scripts/release-audit.mjs",
    "check:release": "npm run lint && npm run test && npm run build && npm run audit:release && npm run test:e2e",
    "check:launch": "node scripts/launch-readiness.mjs",
    "verify:live-supabase": "node scripts/live-supabase-verify.mjs",
    "configure:production": "node scripts/inject-production-config.mjs",
    "build:launch": "npm run configure:production && npm run check && npm run check:launch",
    "check:web-launch": "node scripts/web-launch-readiness.mjs",
    "build:web-launch": "vite build",
    "build:web": "vite build",
    "build:netlify": "bash scripts/netlify-guaranteed-build.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "typescript": "~5.8.2",
    "vite": "8.0.16"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "vitest": "^4.1.8"
  },
  "description": "Tactic Boss V131.4 game-DNA release: authentic PES/eFootball/EA FC settings, diversified playstyles, and no chat or AI-facing branding.",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "packageManager": "npm@10.8.2"
}